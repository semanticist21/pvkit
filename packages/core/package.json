{
  "name": "@pvkit/core",
  "version": "0.0.0",
  "description": "ESM-first PV (solar) performance modeling engine — solar position, irradiance, cell temperature, system output. Numerically validated against reference implementations.",
  "type": "module",
  "license": "MIT",
  "author": "semanticist21",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/semanticist21/pvkit.git",
    "directory": "packages/core"
  },
  "keywords": [
    "pv",
    "solar",
    "photovoltaic",
    "irradiance",
    "solar-position",
    "spa",
    "esm",
    "tree-shaking"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./units": "./src/units.ts",
    "./*": "./src/models/*/index.ts",
    "./solarposition/*": "./src/models/solarposition/*.ts",
    "./atmosphere/*": "./src/models/atmosphere/*.ts",
    "./clearsky/*": "./src/models/clearsky/*.ts",
    "./irradiance/*": "./src/models/irradiance/*.ts",
    "./decomposition/*": "./src/models/decomposition/*.ts",
    "./iam/*": "./src/models/iam/*.ts",
    "./temperature/*": "./src/models/temperature/*.ts",
    "./tracking/*": "./src/models/tracking/*.ts",
    "./pvsystem/*": "./src/models/pvsystem/*.ts",
    "./losses/*": "./src/models/losses/*.ts",
    "./metrics/*": "./src/models/metrics/*.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./units": {
        "types": "./dist/units.d.ts",
        "default": "./dist/units.js"
      },
      "./*": {
        "types": "./dist/models/*/index.d.ts",
        "default": "./dist/models/*/index.js"
      },
      "./solarposition/*": {
        "types": "./dist/models/solarposition/*.d.ts",
        "default": "./dist/models/solarposition/*.js"
      },
      "./atmosphere/*": {
        "types": "./dist/models/atmosphere/*.d.ts",
        "default": "./dist/models/atmosphere/*.js"
      },
      "./clearsky/*": {
        "types": "./dist/models/clearsky/*.d.ts",
        "default": "./dist/models/clearsky/*.js"
      },
      "./irradiance/*": {
        "types": "./dist/models/irradiance/*.d.ts",
        "default": "./dist/models/irradiance/*.js"
      },
      "./decomposition/*": {
        "types": "./dist/models/decomposition/*.d.ts",
        "default": "./dist/models/decomposition/*.js"
      },
      "./iam/*": {
        "types": "./dist/models/iam/*.d.ts",
        "default": "./dist/models/iam/*.js"
      },
      "./temperature/*": {
        "types": "./dist/models/temperature/*.d.ts",
        "default": "./dist/models/temperature/*.js"
      },
      "./tracking/*": {
        "types": "./dist/models/tracking/*.d.ts",
        "default": "./dist/models/tracking/*.js"
      },
      "./pvsystem/*": {
        "types": "./dist/models/pvsystem/*.d.ts",
        "default": "./dist/models/pvsystem/*.js"
      },
      "./losses/*": {
        "types": "./dist/models/losses/*.d.ts",
        "default": "./dist/models/losses/*.js"
      },
      "./metrics/*": {
        "types": "./dist/models/metrics/*.d.ts",
        "default": "./dist/models/metrics/*.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  }
}
