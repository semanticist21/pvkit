{
  "name": "@pvkit/core",
  "version": "0.0.0",
  "description": "ESM-first PV (solar) performance modeling engine — solar position, irradiance, cell temperature, system output. Numerically validated against reference implementations.",
  "type": "module",
  "license": "MIT",
  "author": "semanticist21",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/semanticist21/pvkit.git",
    "directory": "packages/core"
  },
  "keywords": [
    "pv",
    "solar",
    "photovoltaic",
    "irradiance",
    "solar-position",
    "spa",
    "esm",
    "tree-shaking"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./solarposition": "./src/models/solarposition/index.ts",
    "./atmosphere": "./src/models/atmosphere/index.ts",
    "./clearsky": "./src/models/clearsky/index.ts",
    "./irradiance": "./src/models/irradiance/index.ts",
    "./decomposition": "./src/models/decomposition/index.ts",
    "./iam": "./src/models/iam/index.ts",
    "./temperature": "./src/models/temperature/index.ts",
    "./tracking": "./src/models/tracking/index.ts",
    "./pvsystem": "./src/models/pvsystem/index.ts",
    "./losses": "./src/models/losses/index.ts",
    "./metrics": "./src/models/metrics/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./solarposition": {
        "types": "./dist/models/solarposition/index.d.ts",
        "default": "./dist/models/solarposition/index.js"
      },
      "./atmosphere": {
        "types": "./dist/models/atmosphere/index.d.ts",
        "default": "./dist/models/atmosphere/index.js"
      },
      "./clearsky": {
        "types": "./dist/models/clearsky/index.d.ts",
        "default": "./dist/models/clearsky/index.js"
      },
      "./irradiance": {
        "types": "./dist/models/irradiance/index.d.ts",
        "default": "./dist/models/irradiance/index.js"
      },
      "./decomposition": {
        "types": "./dist/models/decomposition/index.d.ts",
        "default": "./dist/models/decomposition/index.js"
      },
      "./iam": {
        "types": "./dist/models/iam/index.d.ts",
        "default": "./dist/models/iam/index.js"
      },
      "./temperature": {
        "types": "./dist/models/temperature/index.d.ts",
        "default": "./dist/models/temperature/index.js"
      },
      "./tracking": {
        "types": "./dist/models/tracking/index.d.ts",
        "default": "./dist/models/tracking/index.js"
      },
      "./pvsystem": {
        "types": "./dist/models/pvsystem/index.d.ts",
        "default": "./dist/models/pvsystem/index.js"
      },
      "./losses": {
        "types": "./dist/models/losses/index.d.ts",
        "default": "./dist/models/losses/index.js"
      },
      "./metrics": {
        "types": "./dist/models/metrics/index.d.ts",
        "default": "./dist/models/metrics/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  }
}
