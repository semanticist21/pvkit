{
  "name": "@pvkit/core",
  "version": "0.0.0",
  "description": "ESM-first PV (solar) performance modeling engine — solar position, irradiance, cell temperature, system output. Numerically validated against reference implementations.",
  "type": "module",
  "license": "MIT",
  "author": "semanticist21",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/semanticist21/pvkit.git",
    "directory": "packages/core"
  },
  "keywords": [
    "pv",
    "solar",
    "photovoltaic",
    "irradiance",
    "solar-position",
    "spa",
    "esm",
    "tree-shaking"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./atmosphere": "./src/models/atmosphere/index.ts",
    "./clearsky": "./src/models/clearsky/index.ts",
    "./decomposition": "./src/models/decomposition/index.ts",
    "./iam": "./src/models/iam/index.ts",
    "./irradiance": "./src/models/irradiance/index.ts",
    "./losses": "./src/models/losses/index.ts",
    "./metrics": "./src/models/metrics/index.ts",
    "./pvsystem": "./src/models/pvsystem/index.ts",
    "./solarposition": "./src/models/solarposition/index.ts",
    "./temperature": "./src/models/temperature/index.ts",
    "./tracking": "./src/models/tracking/index.ts",
    "./units": "./src/units.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./atmosphere": "./dist/models/atmosphere/index.js",
      "./clearsky": "./dist/models/clearsky/index.js",
      "./decomposition": "./dist/models/decomposition/index.js",
      "./iam": "./dist/models/iam/index.js",
      "./irradiance": "./dist/models/irradiance/index.js",
      "./losses": "./dist/models/losses/index.js",
      "./metrics": "./dist/models/metrics/index.js",
      "./pvsystem": "./dist/models/pvsystem/index.js",
      "./solarposition": "./dist/models/solarposition/index.js",
      "./temperature": "./dist/models/temperature/index.js",
      "./tracking": "./dist/models/tracking/index.js",
      "./units": "./dist/units.js",
      "./package.json": "./package.json"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
